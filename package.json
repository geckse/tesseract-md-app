{
  "name": "tesseract-app",
  "version": "0.1.0",
  "productName": "Tesseract",
  "description": "Tesseract - Markdown Editor for mdvdb with superpowers",
  "author": "geckse",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nickarino/markdown-vdb"
  },
  "homepage": "https://github.com/nickarino/markdown-vdb",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "electron-vite build && electron-builder --win",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:all": "electron-vite build && electron-builder --mac --win --linux",
    "publish": "electron-vite build && electron-builder --mac --win --linux --publish always"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.6",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.1",
    "@codemirror/view": "^6.36.2",
    "@floating-ui/dom": "^1.6.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@lezer/highlight": "^1.2.1",
    "@tiptap/core": "^3.0.0",
    "@tiptap/extension-bubble-menu": "^3.0.0",
    "@tiptap/extension-code-block-lowlight": "^3.0.0",
    "@tiptap/extension-image": "^3.0.0",
    "@tiptap/extension-list": "^3.0.0",
    "@tiptap/extension-table": "^3.0.0",
    "@tiptap/extension-typography": "^3.0.0",
    "@tiptap/extensions": "^3.0.0",
    "@tiptap/markdown": "^3.0.0",
    "@tiptap/pm": "^3.0.0",
    "@tiptap/starter-kit": "^3.0.0",
    "@tiptap/suggestion": "^3.0.0",
    "3d-force-graph": "^1.73.0",
    "d3-force": "^3.0.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "js-tiktoken": "^1.0.21",
    "lowlight": "^3.1.0",
    "marked": "^15.0.0",
    "material-symbols": "^0.43.0",
    "mermaid": "^11.0.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/notarize": "^3.0.0",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/svelte": "^5.2.6",
    "@tsconfig/svelte": "^5.0.4",
    "@types/d3-force": "^3.0.0",
    "@types/node": "^22.10.5",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.18.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte": "^5.45.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.1"
  },
  "build": {
    "appId": "md.tesseract.app",
    "productName": "Tesseract",
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "publish": {
      "provider": "github"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        },
        {
          "target": "zip",
          "arch": "universal"
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.png",
      "hardenedRuntime": true,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "notarize": false,
      "afterSign": "scripts/notarize.js"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "resources/icon.png"
    }
  }
}
